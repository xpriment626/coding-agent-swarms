# Copy to .env and fill in real values. Loaded by the orchestration .http files
# via VS Code REST Client's {{$dotenv NAME}} syntax, and referenced in
# CLAUDE.md commands. Not read directly by the agent runtimes — keys are
# injected into agent options at session-create time so Coral forwards them
# as env vars.

# OpenRouter token — all three agents use this as MODEL_API_KEY, with
# MODEL_ID = deepseek/deepseek-v4-flash by default.
OPENROUTER_API_KEY=sk-or-v1-...

# Daytona API key — used by both Claude Code (orchestrator) to create/manage
# sandboxes and by the agents themselves (via the DaytonaToolbox HTTP client)
# to read/write files and run commands in the shared workspace.
DAYTONA_API_KEY=

# Exa API key — hosted MCP research tools (web_search_exa, web_fetch_exa).
# Same pattern as the K2.6 sandbox.
EXA_API_KEY=
